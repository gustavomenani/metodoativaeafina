# Copie para .env e preencha com valores fortes e únicos.
# Na Vercel: Settings → Environment Variables → adicione as mesmas chaves
# (Production + Preview). Nunca use valores de exemplo em produção.

ADMIN_USERNAME=seu_usuario_imprevisivel
ADMIN_PASSWORD=sua_senha_longa_e_aleatoria
ADMIN_SESSION_SECRET=cole_aqui_um_segredo_longo_aleatorio_hex_64_chars
