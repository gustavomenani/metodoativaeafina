---
/**
 * Wrapper do <Image /> do Astro com AVIF/WebP, sizes e lazy/LCP.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  /** LCP: eager + high priority, sem lazy */
  priority?: boolean;
  aspect?: "video" | "square" | "portrait" | "wide" | "side" | "auto";
  fit?: "cover" | "contain";
  class?: string;
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  priority = false,
  aspect = "auto",
  fit = "cover",
  class: className = "",
  widths = [320, 480, 640, 800, 960],
  sizes = "(max-width: 768px) 90vw, 420px",
} = Astro.props;

const aspectMap: Record<string, string> = {
  video: "aspect-video",
  square: "aspect-square",
  portrait: "aspect-[3/4]",
  wide: "aspect-[16/10]",
  side: "aspect-[4/5]",
  auto: "",
};
---

<figure class:list={["w-full", className]}>
  <div
    class:list={[
      "relative overflow-hidden rounded-2xl bg-slate-100",
      aspectMap[aspect] || "aspect-auto",
      aspect === "auto" && "min-h-0",
    ]}
  >
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      formats={["avif", "webp"]}
      quality={80}
      loading={priority ? "eager" : "lazy"}
      decoding={priority ? "sync" : "async"}
      fetchpriority={priority ? "high" : "auto"}
      class:list={[
        "h-full w-full",
        fit === "contain" ? "object-contain" : "object-cover",
        aspect === "auto" ? "h-auto w-full" : "absolute inset-0",
      ]}
    />
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm leading-relaxed text-ink-muted sm:text-base">
        {caption}
      </figcaption>
    )
  }
</figure>
