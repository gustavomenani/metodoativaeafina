---
/**
 * Player de vídeo — iframe (YouTube/Vimeo) ou arquivo local MP4.
 * aspect: "video" 16:9 | "reels" 9:16 | "square" 1:1
 */
interface Props {
  embedUrl?: string;
  src?: string;
  poster?: string;
  title: string;
  aspect?: "video" | "reels" | "square";
  class?: string;
  autoplay?: boolean;
}

const {
  embedUrl,
  src,
  poster,
  title,
  aspect = "video",
  class: className = "",
  autoplay = false,
} = Astro.props;

const aspectClass = {
  video: "aspect-video",
  reels: "aspect-[9/16]",
  square: "aspect-square",
}[aspect];
---

<div
  class:list={[
    "relative w-full overflow-hidden bg-ink shadow-xl shadow-ink/15",
    aspect === "reels" ? "rounded-[1.75rem]" : "rounded-2xl",
    aspectClass,
    className,
  ]}
>
  {
    embedUrl ? (
      <iframe
        src={embedUrl}
        title={title}
        class="absolute inset-0 h-full w-full border-0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
      />
    ) : src ? (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        controls
        playsinline
        preload="metadata"
        poster={poster}
        title={title}
        autoplay={autoplay}
        muted={autoplay}
      >
        <source src={src} type="video/mp4" />
        Seu navegador não suporta a reprodução deste vídeo.
      </video>
    ) : null
  }
</div>
