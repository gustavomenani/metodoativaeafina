---
/**
 * Player de vídeo — iframe (YouTube/Vimeo) ou arquivo local MP4.
 * aspect: "video" 16:9 | "reels" 9:16 | "square" 1:1
 *
 * Para MP4: capa de marca + clique para assistir (não mostra o frame
 * do rosto até a aluna tocar em play).
 */
interface Props {
  embedUrl?: string;
  src?: string;
  poster?: string;
  title: string;
  aspect?: "video" | "reels" | "square";
  class?: string;
  autoplay?: boolean;
  /** Eyebrow da capa HTML (quando não há poster) */
  coverEyebrow?: string;
  /** Linha 1 do título na capa */
  coverTitle?: string;
  /** Trecho em destaque (amarelo) no título — ex.: "Ativa & Afina" */
  coverTitleHighlight?: string;
  /** Texto do botão CTA da capa */
  coverCta?: string;
  /** Nome + idade da aluna na capa de depoimento — ex.: "Amanda, 35 anos" */
  coverName?: string;
  /** Frase curta da aluna na capa de depoimento */
  coverQuote?: string;
  /** Se false, não usa overlay de capa (só poster nativo) */
  brandedCover?: boolean;
}

const {
  embedUrl,
  src,
  poster,
  title,
  aspect = "video",
  class: className = "",
  autoplay = false,
  coverEyebrow = "Descubra",
  coverTitle = "Como funciona o",
  coverTitleHighlight = "Método Ativa & Afina",
  coverCta = "Assistir agora",
  coverName,
  coverQuote,
  brandedCover = true,
} = Astro.props;

/** Capa de depoimento (nome + frase da aluna), renderizada em HTML para
 *  garantir cores e tamanhos idênticos entre todos os depoimentos. */
const isTestimonial = Boolean(coverName && coverQuote);

const aspectClass = {
  video: "aspect-video",
  reels: "aspect-[9/16]",
  square: "aspect-square",
}[aspect];

const useCover = Boolean(src) && brandedCover && !autoplay;
const uid = `vid-${Math.random().toString(36).slice(2, 10)}`;
const usePosterImage = Boolean(poster);
---

<div
  class:list={[
    "relative w-full overflow-hidden bg-[#0f2828] shadow-xl shadow-ink/15",
    aspect === "reels" ? "rounded-[1.75rem]" : "rounded-2xl",
    aspectClass,
    className,
  ]}
  data-video-player={useCover ? uid : undefined}
>
  {
    embedUrl ? (
      <iframe
        src={embedUrl}
        title={title}
        class="absolute inset-0 h-full w-full border-0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
      />
    ) : src ? (
      <>
        <video
          class="absolute inset-0 h-full w-full object-cover"
          controls={!useCover}
          playsinline
          preload={useCover ? "none" : "metadata"}
          poster={poster}
          title={title}
          autoplay={autoplay}
          muted={autoplay}
          data-video-el={useCover ? uid : undefined}
        >
          <source src={src} type="video/mp4" />
          Seu navegador não suporta a reprodução deste vídeo.
        </video>

        {useCover && (
          <button
            type="button"
            class="group absolute inset-0 z-10 flex flex-col items-center justify-center px-5 text-center transition-opacity duration-300 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-sun"
            data-video-cover={uid}
            aria-label={`${coverTitle} ${coverTitleHighlight}. ${title}`}
          >
            {isTestimonial ? (
              /* Capa de depoimento em HTML — mesmas cores e tamanhos p/ todas */
              <span
                class="absolute inset-0 bg-[linear-gradient(155deg,#1e3231_0%,#122b29_48%,#0a2120_100%)]"
                aria-hidden="true"
              />
            ) : usePosterImage ? (
              /* Capa gerada (estilo da referência da cliente) */
              <img
                src={poster}
                alt=""
                width="720"
                height="1280"
                class="absolute inset-0 h-full w-full object-cover"
                draggable="false"
              />
            ) : (
              /* Fallback HTML no mesmo estilo da referência */
              <span class="absolute inset-0 bg-gradient-to-b from-[#5a6e46] via-[#143333] to-[#0a1a1a]" />
            )}

            {isTestimonial && (
              <span class="relative z-[1] flex h-full w-full flex-col items-center px-5 pt-[13%] pb-[9%] text-center">
                <span class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-olive-light">
                  Depoimento
                </span>
                <span
                  class="mt-2.5 h-[3px] w-9 rounded-full bg-sun"
                  aria-hidden="true"
                />

                <span class="mt-6 font-display text-xl font-bold leading-tight text-white sm:text-2xl">
                  {coverName}
                </span>

                <span class="mt-3 max-w-[15rem] text-sm leading-snug text-olive-light/95 sm:text-[0.95rem]">
                  “{coverQuote}”
                </span>

                <span class="flex flex-1 items-center justify-center py-4">
                  <span
                    class="flex h-[5.5rem] w-[5.5rem] items-center justify-center rounded-full bg-white shadow-lg ring-[8px] ring-sun transition-transform duration-200 group-hover:scale-105 group-active:scale-95 sm:h-[6.25rem] sm:w-[6.25rem]"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="38"
                      height="38"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="ml-1 text-[#0f2828]"
                    >
                      <path d="M8 5.14v13.72L19 12 8 5.14z" />
                    </svg>
                  </span>
                </span>

                <span class="inline-flex w-full max-w-[15rem] items-center justify-center gap-2 whitespace-nowrap rounded-2xl bg-sun px-4 py-3.5 text-sm font-bold uppercase tracking-wide text-ink shadow-md sm:text-base">
                  {coverCta}
                  <span
                    class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border-2 border-ink"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="10"
                      height="10"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="ml-[1px]"
                    >
                      <path d="M8 5.14v13.72L19 12 8 5.14z" />
                    </svg>
                  </span>
                </span>
              </span>
            )}

            {
              !isTestimonial && !usePosterImage && (
                <span class="relative z-[1] flex h-full w-full flex-col items-center px-4 pt-[12%] pb-[10%]">
                  <span class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-[#c4cd96]">
                    {coverEyebrow}
                  </span>
                  <span
                    class="mt-2.5 h-[3px] w-9 rounded-full bg-sun"
                    aria-hidden="true"
                  />

                  <span class="mt-7 max-w-[16rem]">
                    <span class="block text-lg font-medium leading-snug text-white sm:text-xl">
                      {coverTitle}
                    </span>
                    <span class="mt-1 block font-display text-xl font-bold leading-snug sm:text-2xl">
                      {coverTitleHighlight.includes("Ativa") ? (
                        <>
                          <span class="text-white">Método </span>
                          <span class="text-sun">Ativa &amp; Afina</span>
                        </>
                      ) : (
                        <span class="text-white">{coverTitleHighlight}</span>
                      )}
                    </span>
                  </span>

                  <span class="flex flex-1 items-center justify-center">
                    <span
                      class="flex h-[4.75rem] w-[4.75rem] items-center justify-center rounded-full bg-white shadow-lg ring-[10px] ring-sun transition-transform duration-200 group-hover:scale-105 group-active:scale-95 sm:h-[5.25rem] sm:w-[5.25rem]"
                      aria-hidden="true"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="34"
                        height="34"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="ml-1 text-[#0f2828]"
                      >
                        <path d="M8 5.14v13.72L19 12 8 5.14z" />
                      </svg>
                    </span>
                  </span>

                  <span class="inline-flex min-w-[14rem] items-center justify-center rounded-2xl bg-sun px-10 py-4 text-base font-bold uppercase tracking-wide text-ink shadow-md sm:min-w-[16rem] sm:text-lg">
                    {coverCta}
                  </span>
                </span>
              )
            }

            {/* Área clicável sempre por cima da imagem */}
            <span class="absolute inset-0 z-[2]" aria-hidden="true" />
          </button>
        )}
      </>
    ) : (
      /* Placeholder depoimento (sem vídeo ainda) — mesma estética */
      <div
        class="absolute inset-0"
        role="img"
        aria-label={`${title} — em breve`}
      >
        {poster ? (
          <img
            src={poster}
            alt=""
            width="720"
            height="1280"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-b from-[#5a6e46] via-[#143333] to-[#0a1a1a] px-4 text-center">
            <span class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-[#c4cd96]">
              Em breve
            </span>
            <span
              class="flex h-14 w-14 items-center justify-center rounded-full bg-white ring-[8px] ring-sun"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="ml-0.5 text-[#0f2828]"
              >
                <path d="M8 5.14v13.72L19 12 8 5.14z" />
              </svg>
            </span>
            <p class="text-sm font-semibold text-white/95">Depoimento em vídeo</p>
          </div>
        )}
      </div>
    )
  }
</div>

<script>
  function initBrandedVideoCovers() {
    document.querySelectorAll<HTMLElement>("[data-video-cover]").forEach((cover) => {
      if (cover.dataset.bound === "1") return;
      cover.dataset.bound = "1";

      const uid = cover.getAttribute("data-video-cover");
      if (!uid) return;

      const video = document.querySelector<HTMLVideoElement>(
        `[data-video-el="${uid}"]`,
      );
      if (!video) return;

      const start = () => {
        cover.classList.add("pointer-events-none", "opacity-0");
        video.setAttribute("controls", "");
        void video.play().catch(() => {});
        window.setTimeout(() => cover.remove(), 320);
      };

      cover.addEventListener("click", start);
    });
  }

  initBrandedVideoCovers();
  document.addEventListener("astro:page-load", initBrandedVideoCovers);
</script>
