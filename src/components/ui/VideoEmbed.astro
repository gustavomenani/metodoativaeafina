---
/**
 * Player de vídeo — iframe (YouTube/Vimeo) ou arquivo local MP4.
 * aspect: "video" 16:9 | "reels" 9:16 | "square" 1:1
 */
interface Props {
  embedUrl?: string;
  src?: string;
  poster?: string;
  title: string;
  aspect?: "video" | "reels" | "square";
  class?: string;
  autoplay?: boolean;
}

const {
  embedUrl,
  src,
  poster,
  title,
  aspect = "video",
  class: className = "",
  autoplay = false,
} = Astro.props;

const aspectClass = {
  video: "aspect-video",
  reels: "aspect-[9/16]",
  square: "aspect-square",
}[aspect];
---

<div
  class:list={[
    "relative w-full overflow-hidden bg-ink shadow-xl shadow-ink/15",
    aspect === "reels" ? "rounded-[1.75rem]" : "rounded-2xl",
    aspectClass,
    className,
  ]}
>
  {
    embedUrl ? (
      <iframe
        src={embedUrl}
        title={title}
        class="absolute inset-0 h-full w-full border-0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
      />
    ) : src ? (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        controls
        playsinline
        preload="metadata"
        poster={poster}
        title={title}
        autoplay={autoplay}
        muted={autoplay}
      >
        <source src={src} type="video/mp4" />
        Seu navegador não suporta a reprodução deste vídeo.
      </video>
    ) : (
      <div
        class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-teal-deep to-ink px-4 text-center"
        role="img"
        aria-label={`${title} — em breve`}
      >
        <span
          class="flex h-14 w-14 items-center justify-center rounded-full bg-white/15 ring-2 ring-white/30"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="ml-0.5 text-white"
          >
            <path d="M8 5.14v13.72L19 12 8 5.14z"></path>
          </svg>
        </span>
        <p class="text-sm font-semibold text-white/95">Depoimento em vídeo</p>
        <p class="text-xs text-white/70">Em breve</p>
      </div>
    )
  }
</div>
