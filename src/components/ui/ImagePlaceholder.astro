---
/**
 * Placeholder otimizado para imagens.
 * Substitua `src` por arquivos reais em /public/images/ ou use o Image do Astro em src/assets/.
 *
 * Uso com imagem real (public):
 *   <ImagePlaceholder src="/images/hero-antes-depois.webp" alt="..." priority />
 *
 * Uso com Image do Astro (recomendado para LCP/WebP):
 *   import { Image } from 'astro:assets';
 *   import foto from '../assets/hero.webp';
 *   <Image src={foto} alt="..." widths={[400, 800]} formats={['avif','webp']} />
 */
interface Props {
  src?: string;
  alt: string;
  caption?: string;
  /** LCP: desativa lazy e prioriza fetch */
  priority?: boolean;
  aspect?: "video" | "square" | "portrait" | "wide" | "side";
  class?: string;
  label?: string;
}

const {
  src,
  alt,
  caption,
  priority = false,
  aspect = "video",
  class: className = "",
  label = "PLACEHOLDER",
} = Astro.props;

const aspectMap = {
  video: "aspect-video",
  square: "aspect-square",
  portrait: "aspect-[3/4]",
  wide: "aspect-[16/10]",
  side: "aspect-[4/5]",
};
---

<figure class:list=["w-full", className]>
  <div
    class:list={[
      "relative overflow-hidden rounded-2xl bg-gradient-to-br from-olive-soft via-teal-soft to-olive-light",
      aspectMap[aspect],
    ]}
  >
    {
      src ? (
        <img
          src={src}
          alt={alt}
          width={800}
          height={aspect === "portrait" || aspect === "side" ? 1000 : 500}
          loading={priority ? "eager" : "lazy"}
          decoding={priority ? "sync" : "async"}
          fetchpriority={priority ? "high" : "auto"}
          class="absolute inset-0 h-full w-full object-cover"
        />
      ) : (
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 p-4 text-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-teal-deep/50"
            aria-hidden="true"
          >
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
            <circle cx="9" cy="9" r="2" />
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
          </svg>
          <span class="text-[10px] font-bold uppercase tracking-widest text-teal-deep/60">
            {label}
          </span>
          <span class="max-w-[14rem] text-xs text-ink-muted/80">{alt}</span>
        </div>
      )
    }
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm leading-relaxed text-ink-muted sm:text-base">
        {caption}
      </figcaption>
    )
  }
</figure>
