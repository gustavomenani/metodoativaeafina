---
interface Props {
  eyebrow?: string;
  title: string;
  id?: string;
  align?: "left" | "center";
  light?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  id,
  align = "center",
  light = false,
  class: className = "",
} = Astro.props;
---

<div
  class:list={[
    "reveal mx-auto max-w-3xl",
    align === "center" ? "text-center" : "text-left",
    className,
  ]}
>
  {
    eyebrow && (
      <p
        class:list={[
          "mb-3 text-xs font-semibold uppercase tracking-[0.18em] sm:text-sm",
          light ? "text-olive-light" : "text-teal",
        ]}
      >
        {eyebrow}
      </p>
    )
  }
  <h2
    id={id}
    class:list={[
      "font-display text-2xl font-bold leading-tight tracking-tight sm:text-3xl md:text-4xl",
      light ? "text-white" : "text-ink",
    ]}
  >
    {title}
  </h2>
</div>
