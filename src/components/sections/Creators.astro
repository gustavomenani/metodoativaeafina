---
import { Image } from "astro:assets";
import SectionTitle from "../ui/SectionTitle.astro";
import criadoras from "../../assets/images/criadoras/lilian-manu.webp";
import { siteConfig, content } from "../../config/site";

const { lilian, manu } = siteConfig.contact.creators;
const cs = content.creatorsSection;
---

<section
  class="bg-surface py-14 sm:py-20"
  aria-labelledby="criadoras-title"
  id="criadoras"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <SectionTitle
      id="criadoras-title"
      eyebrow={cs.eyebrow}
      title={cs.title}
      class="mb-10 sm:mb-12"
    />

    <div class="reveal grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
      <div
        class="overflow-hidden rounded-2xl bg-slate-100 shadow-lg shadow-ink/10 ring-1 ring-slate-100"
      >
        <Image
          src={criadoras}
          alt={cs.imageAlt}
          widths={[400, 640, 800, 1000, 1200]}
          sizes="(max-width: 1024px) 90vw, 480px"
          formats={["avif", "webp"]}
          quality={84}
          loading="lazy"
          decoding="async"
          class="h-auto w-full object-cover object-top"
        />
      </div>

      <div class="space-y-6">
        <article
          class="reveal reveal-delay-1 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 sm:p-6"
        >
          <h3 class="font-display text-xl font-bold text-ink">
            {lilian.name}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-muted sm:text-base">
            {lilian.role}
          </p>
          <a
            href={lilian.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3.5 inline-flex items-center gap-2 rounded-full bg-teal-soft/70 px-3.5 py-1.5 text-sm font-semibold text-teal-deep ring-1 ring-teal/15 transition-colors hover:bg-teal-soft hover:ring-teal/30"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
            {lilian.instagramHandle}
            <span class="sr-only"> — Instagram de {lilian.name}</span>
          </a>
        </article>

        <article
          class="reveal reveal-delay-2 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-100 sm:p-6"
        >
          <h3 class="font-display text-xl font-bold text-ink">
            {manu.name}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-muted sm:text-base">
            {manu.role}
          </p>
          <a
            href={manu.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3.5 inline-flex items-center gap-2 rounded-full bg-teal-soft/70 px-3.5 py-1.5 text-sm font-semibold text-teal-deep ring-1 ring-teal/15 transition-colors hover:bg-teal-soft hover:ring-teal/30"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
            {manu.instagramHandle}
            <span class="sr-only"> — Instagram de {manu.name}</span>
          </a>
        </article>

        <blockquote
          class="reveal reveal-delay-3 border-l-4 border-sun pl-4 font-display text-lg font-semibold italic leading-snug text-teal-deep sm:text-xl"
        >
          "A união entre a ciência e o movimento para cuidar da sua
          autoestima."
        </blockquote>
      </div>
    </div>
  </div>
</section>
