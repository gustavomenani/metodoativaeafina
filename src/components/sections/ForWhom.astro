---
import SectionTitle from "../ui/SectionTitle.astro";

const items = [
  "Se incomoda com a barriga constantemente estufada.",
  "Tem aquela pochete abaixo do umbigo que não sai por nada.",
  "É mãe e sente que a sua barriga nunca mais voltou ao normal após a gravidez.",
  "Treina, se alimenta bem e mesmo assim continua com a barriga para frente.",
  "É magra, mas sofre com aquela barriguinha saliente que insiste em aparecer na roupa.",
  "Deixou de usar roupas justas ou biquíni por vergonha do formato da barriga.",
  "Se incomoda com a flacidez muscular na barriga e quer devolver a firmeza e o tônus para o abdômen.",
  "Quer reduzir as medidas da circunferência abdominal e afinar a linha da cintura.",
  "Deseja melhorar a postura.",
];
---

<section
  class="bg-surface py-14 sm:py-20"
  aria-labelledby="para-quem-title"
  id="para-quem"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <SectionTitle
      id="para-quem-title"
      eyebrow="É para você?"
      title="O Método Ativa & Afina foi feito para você que:"
      class="mb-8 sm:mb-10"
    />

    <ul class="space-y-3 sm:space-y-3.5" role="list">
      {
        items.map((item, i) => (
          <li
            class:list={[
              "reveal flex gap-3 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-100 sm:p-5",
              // Alterna deslize esq/dir + atraso em cascata ao rolar
              i % 2 === 0 ? "reveal-slide" : "reveal-slide-right",
            ]}
            style={`--stagger: ${i}`}
          >
            <span
              class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-teal text-white"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </span>
            <span class="text-sm leading-relaxed text-ink sm:text-base">
              {item}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
