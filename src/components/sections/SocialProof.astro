---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CtaButton from "../ui/CtaButton.astro";
import VideoEmbed from "../ui/VideoEmbed.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import maristela from "../../assets/images/resultados/maristela.webp";
import lilian from "../../assets/images/resultados/lilian.webp";
import natalia from "../../assets/images/resultados/natalia.webp";
import manequim from "../../assets/images/hero/antes-depois.webp";

const results: {
  image: ImageMetadata;
  alt: string;
}[] = [
  {
    image: maristela,
    alt: "Antes e depois de Maristela, 45 anos — Método Ativa & Afina.",
  },
  {
    image: lilian,
    alt: "Antes e depois de Lilian, 41 anos — Método Ativa & Afina.",
  },
  {
    image: natalia,
    alt: "Antes e depois de Natália, 40 anos — resultado em 4 semanas com o Método Ativa & Afina.",
  },
  {
    image: manequim,
    alt: "Resultado real: de manequim 42 para 38 com o Método Ativa & Afina.",
  },
];

const videoTestimonials = [
  { title: "Depoimento em vídeo 1 — aluna do Método Ativa & Afina" },
  { title: "Depoimento em vídeo 2 — aluna do Método Ativa & Afina" },
  { title: "Depoimento em vídeo 3 — aluna do Método Ativa & Afina" },
];
---

<section
  class="bg-gradient-to-b from-teal-soft/80 via-olive-soft/60 to-surface py-14 sm:py-20"
  aria-labelledby="prova-social-title"
  id="resultados"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle
      id="prova-social-title"
      eyebrow="Prova social"
      title="Veja a Transformação de Mulheres que Seguiram a Metodologia certa e Ativaram sua Cinta Modeladora Natural"
      class="mb-10 sm:mb-12"
    />

    <div
      class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 scrollbar-none sm:gap-5 md:grid md:grid-cols-2 lg:grid-cols-4 md:overflow-visible md:pb-0"
      role="list"
    >
      {
        results.map((item, i) => (
          <div
            class:list={[
              "reveal w-[78%] max-w-xs shrink-0 snap-center md:w-auto md:max-w-none",
              i === 1 && "reveal-delay-1",
              i === 2 && "reveal-delay-2",
              i === 3 && "reveal-delay-3",
            ]}
            role="listitem"
          >
            <div class="overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-black/5">
              <Image
                src={item.image}
                alt={item.alt}
                widths={[240, 320, 480, 640]}
                sizes="(max-width: 768px) 78vw, (max-width: 1024px) 45vw, 260px"
                formats={["avif", "webp"]}
                quality={72}
                loading="lazy"
                decoding="async"
                class="h-auto w-full"
              />
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-2 text-center text-xs text-ink-muted md:hidden">
      ← Arraste para ver todas as transformações →
    </p>

    <h3
      class="reveal mt-12 mb-6 text-center font-display text-xl font-bold text-ink sm:text-2xl"
    >
      Depoimentos em vídeo
    </h3>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        videoTestimonials.map((v, i) => (
          <div
            class:list={[
              "reveal",
              i === 1 && "reveal-delay-1",
              i === 2 && "reveal-delay-2",
            ]}
          >
            <VideoEmbed title={v.title} embedUrl={undefined} />
          </div>
        ))
      }
    </div>

    <div class="reveal mt-10 flex justify-center">
      <CtaButton
        label="QUERO TER ESSES RESULTADOS NA MINHA BARRIGA"
        size="large"
      />
    </div>
  </div>
</section>
