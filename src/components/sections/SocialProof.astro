---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CtaButton from "../ui/CtaButton.astro";
import VideoEmbed from "../ui/VideoEmbed.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import resultadoA from "../../assets/images/resultados/resultado-a.webp";
import resultadoB from "../../assets/images/resultados/resultado-b.webp";
import maristela from "../../assets/images/resultados/maristela.webp";

const results: {
  image: ImageMetadata;
  alt: string;
  quote: string;
  name: string;
  age: string;
}[] = [
  {
    image: maristela,
    alt: "Antes e depois de Maristela com o Método Ativa & Afina.",
    quote:
      "Depois dos 40, achei que minha pochete não tinha mais solução. Treinava, fazia dieta e nada da pochete desaparecer. Com o Método Ativa e Afina consegui reduzir a projeção da barriga e melhorar minha postura.",
    name: "Maristela",
    age: "45 anos",
  },
  {
    image: resultadoA,
    alt: "Antes e depois de Lilian com o Método Ativa & Afina.",
    quote:
      "Como mãe, o que mais me impressionou foi perceber minha barriga mais firme e a cintura mais fina. O abdômen voltou para o lugar sem precisar perder peso e o estufamento acabou.",
    name: "Lilian",
    age: "41 anos",
  },
  {
    image: resultadoB,
    alt: "Antes e depois de Natália com o Método Ativa & Afina.",
    quote:
      "Em apenas 4 semanas, já perdi medidas na barriga. Mesmo acima do peso, minhas roupas voltaram a servir sem apertar.",
    name: "Natália",
    age: "40 anos",
  },
];

/** Quando os vídeos chegarem, preencha `src` (MP4 em /public/videos/) ou `embedUrl` (YouTube/Vimeo). */
const videoTestimonials: {
  title: string;
  src?: string;
  embedUrl?: string;
  poster?: string;
  coverTitle?: string;
  coverTitleHighlight?: string;
  coverCta?: string;
}[] = [
  {
    title: "Depoimento em vídeo — Amanda, 35 anos",
    src: "/videos/depoimento-amanda.mp4",
    poster: "/videos/depoimento-amanda-poster.webp",
    coverTitle: "Veja o que nossas",
    coverTitleHighlight: "alunas têm a dizer",
    coverCta: "Assistir agora",
  },
  {
    title: "Depoimento em vídeo — Luana, 30 anos",
    src: "/videos/depoimento-luana.mp4",
    poster: "/videos/depoimento-luana-poster.webp",
    coverTitle: "Veja o que nossas",
    coverTitleHighlight: "alunas têm a dizer",
    coverCta: "Assistir agora",
  },
  {
    title: "Depoimento em vídeo — Priscila, 38 anos",
    src: "/videos/depoimento-priscila.mp4",
    poster: "/videos/depoimento-priscila-poster.webp",
    coverTitle: "Veja o que nossas",
    coverTitleHighlight: "alunas têm a dizer",
    coverCta: "Assistir agora",
  },
];
---

<section
  class="bg-gradient-to-b from-teal-soft/80 via-olive-soft/60 to-surface py-14 sm:py-20"
  aria-labelledby="prova-social-title"
  id="resultados"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle
      id="prova-social-title"
      eyebrow="Resultados reais"
      title="Veja o que acontece quando você ativa sua Cinta Modeladora Natural"
      class="mb-10 sm:mb-12"
    />

    <div
      class="flex snap-x snap-mandatory items-stretch gap-4 overflow-x-auto pb-3 scrollbar-none sm:gap-5 md:grid md:grid-cols-3 md:overflow-visible md:pb-0"
      role="list"
    >
      {
        results.map((item, i) => (
          <article
            class:list={[
              "reveal flex w-[78%] max-w-xs shrink-0 snap-center flex-col md:w-auto md:max-w-none",
              i === 1 && "reveal-delay-1",
              i === 2 && "reveal-delay-2",
              i === 3 && "reveal-delay-3",
            ]}
            role="listitem"
          >
            <div class="flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-black/5">
              <div class="relative aspect-[3/4] w-full shrink-0 bg-slate-50">
                <Image
                  src={item.image}
                  alt={item.alt}
                  widths={[280, 360, 480, 640, 800]}
                  sizes="(max-width: 768px) 78vw, (max-width: 1024px) 45vw, 280px"
                  formats={["avif", "webp"]}
                  quality={84}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-contain object-center"
                />
              </div>

              <div class="flex flex-1 flex-col p-4 sm:p-5">
                <p class="text-sm leading-relaxed text-ink-muted">
                  “{item.quote}”
                </p>
                <div class="mt-auto flex items-center gap-2 border-t border-slate-100 pt-3">
                  <span
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal-soft text-xs font-bold text-teal-deep"
                    aria-hidden="true"
                  >
                    {item.name.charAt(0)}
                  </span>
                  <div class="min-w-0 text-left">
                    <p class="text-sm font-bold text-ink">{item.name}</p>
                    <p class="text-xs text-ink-muted">{item.age}</p>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-3 text-center text-xs text-ink-muted md:hidden" aria-hidden="true">
      Deslize para o lado para ver mais resultados
    </p>

    <!-- Depoimentos em vídeo (3 slots — vídeos chegam depois) -->
    <div class="mt-14 sm:mt-16" id="depoimentos">
      <h3
        class="reveal mb-2 text-center font-display text-xl font-bold text-ink sm:text-2xl md:text-3xl"
      >
        Veja o que nossas alunas têm a dizer
      </h3>
      <p
        class="reveal reveal-delay-1 mx-auto mb-8 max-w-xl text-center text-sm leading-relaxed text-ink-muted sm:text-base"
      >
        Histórias reais de mulheres que transformaram a aparência da barriga com
        o Método Ativa &amp; Afina.
      </p>

      <div
        class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-3 scrollbar-none sm:gap-5 md:grid md:grid-cols-3 md:overflow-visible md:pb-0"
        role="list"
      >
        {
          videoTestimonials.map((v, i) => (
            <div
              class:list={[
                "reveal w-[72%] max-w-xs shrink-0 snap-center md:w-auto md:max-w-none",
                i === 1 && "reveal-delay-1",
                i === 2 && "reveal-delay-2",
              ]}
              role="listitem"
            >
              <VideoEmbed
                title={v.title}
                src={v.src}
                embedUrl={v.embedUrl}
                poster={v.poster}
                coverTitle={v.coverTitle}
                coverTitleHighlight={v.coverTitleHighlight}
                coverCta={v.coverCta}
                aspect="reels"
              />
            </div>
          ))
        }
      </div>

      <p
        class="mt-3 text-center text-xs text-ink-muted md:hidden"
        aria-hidden="true"
      >
        Deslize para o lado para ver os depoimentos
      </p>
    </div>

    <div class="reveal mt-10 flex justify-center sm:mt-12">
      <CtaButton
        label="QUERO TER ESSES RESULTADOS NA MINHA BARRIGA"
        size="large"
      />
    </div>
  </div>
</section>
