---
import SectionTitle from "../ui/SectionTitle.astro";

const items = [
  {
    icon: "program",
    title: "Programa Completo de 8 Semanas",
    text: "Vídeos curtos, simples e didáticos (5 a 20 minutos) para fazer em casa apenas com um tapete e garrafa d'água.",
  },
  {
    icon: "access",
    title: "1 Ano de Acesso Livre",
    text: "Veja e reveja no seu próprio tempo sempre que quiser.",
  },
  {
    icon: "bonus1",
    title: "BÔNUS 1: O Guia de Medidas e Planner de Evolução (PDF)",
    text: "Para você rastrear perfeitamente cada centímetro que for perdendo.",
  },
  {
    icon: "bonus2",
    title: "BÔNUS 2: Automassagem Modeladora Abdominal",
    text: "Técnica manual rápida para reduzir a retenção de líquidos, melhorar o funcionamento do intestino e ajudar a diminuir ainda mais as medidas da circunferência abdominal.",
  },
  {
    icon: "bonus3",
    title: "BÔNUS 3: Guia Pós-Curso",
    text: "Aprenda como manter sua barriga mais firme e cintura mais definida após as 8 semanas, com orientações práticas para a sua rotina.",
  },
];
---

<section
  class="bg-white py-14 sm:py-20"
  aria-labelledby="voce-recebe-title"
  id="voce-recebe"
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <SectionTitle
      id="voce-recebe-title"
      eyebrow="Seu acesso"
      title="O que você vai receber"
      class="mb-10 sm:mb-12"
    />

    <div class="grid gap-4 sm:gap-5">
      {
        items.map((item, i) => (
          <article
            class:list={[
              "reveal flex gap-4 rounded-2xl border border-slate-100 bg-surface p-5 sm:gap-5 sm:p-6",
              i % 2 === 1 && "reveal-delay-1",
            ]}
          >
            <div
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-teal text-white sm:h-14 sm:w-14"
              aria-hidden="true"
            >
              {item.icon === "program" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
              )}
              {item.icon === "access" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              )}
              {item.icon === "bonus1" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                  <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                  <path d="M10 9H8" />
                  <path d="M16 13H8" />
                  <path d="M16 17H8" />
                </svg>
              )}
              {item.icon === "bonus2" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 12v10H4V12" />
                  <path d="M2 7h20v5H2z" />
                  <path d="M12 22V7" />
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
                </svg>
              )}
              {item.icon === "bonus3" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-display text-lg font-bold text-ink sm:text-xl">
                {item.title}
              </h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-muted sm:text-base">
                {item.text}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
