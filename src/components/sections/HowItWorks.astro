---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CtaButton from "../ui/CtaButton.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import passo1 from "../../assets/images/passos/passo-1-respiracao.webp";
import passo2 from "../../assets/images/passos/passo-2-ativacao.webp";
import passo3 from "../../assets/images/passos/passo-3-funcional.webp";

const steps: {
  num: string;
  title: string;
  text: string;
  alt: string;
  image: ImageMetadata;
}[] = [
  {
    num: "01",
    title: "Exercícios Respiratórios Iniciais",
    text: "Você vai aprender uma respiração simples que ajuda a controlar a pressão interna, impedindo que a sua barriga seja empurrada para frente no dia a dia.",
    alt: "Demonstração do exercício respiratório inicial do Método Ativa & Afina.",
    image: passo1,
  },
  {
    num: "02",
    title: "Ativação Profunda",
    text: "O passo onde você aprende a ativar a musculatura mais profunda do abdômen, que funciona como a sua verdadeira cinta natural, puxando a barriga e a pochete de volta para o lugar.",
    alt: "Demonstração da ativação profunda do abdômen bem colado e firme.",
    image: passo2,
  },
  {
    num: "03",
    title: "Exercícios Funcionais Combinados",
    text: "Treinos em vídeo muito rápidos e práticos para acelerar a queima de gordura e deixar o seu corpo e o seu abdômen muito mais firmes.",
    alt: "Demonstração dos exercícios funcionais do Método Ativa & Afina.",
    image: passo3,
  },
];
---

<section
  class="bg-white py-14 sm:py-20"
  aria-labelledby="como-funciona-title"
  id="como-funciona"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionTitle
      id="como-funciona-title"
      eyebrow="Como funciona"
      title="O Caminho Simples para Mudar a Aparência da sua Barriga"
      class="mb-10 sm:mb-12"
    />

    <div
      class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-4 scrollbar-none sm:gap-5 md:grid md:grid-cols-3 md:overflow-visible md:pb-0"
      role="list"
    >
      {
        steps.map((step, i) => (
          <article
            class:list={[
              "reveal w-[85%] max-w-sm shrink-0 snap-center rounded-2xl border border-olive-light/40 bg-olive-soft/40 p-4 shadow-sm sm:w-[70%] sm:p-5 md:w-auto md:max-w-none",
              i === 1 && "reveal-delay-1",
              i === 2 && "reveal-delay-2",
            ]}
            role="listitem"
          >
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal text-sm font-bold text-white">
                {step.num}
              </span>
              <span class="text-xs font-semibold uppercase tracking-wider text-teal">
                Passo {step.num.replace("0", "")}
              </span>
            </div>

            <div class="mb-4 overflow-hidden rounded-2xl bg-white shadow-sm">
              <Image
                src={step.image}
                alt={step.alt}
                widths={[360, 480, 640, 800, 1000]}
                sizes="(max-width: 768px) 85vw, 360px"
                formats={["avif", "webp"]}
                quality={84}
                loading="lazy"
                decoding="async"
                class="aspect-video h-auto w-full object-cover"
              />
            </div>

            <h3 class="font-display text-lg font-bold text-ink sm:text-xl">
              {step.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted sm:text-base">
              {step.text}
            </p>
          </article>
        ))
      }
    </div>

    <p class="mt-3 text-center text-xs text-ink-muted md:hidden" aria-hidden="true">
      Deslize para o lado para ver os 3 passos
    </p>

    <div class="reveal mt-10 flex justify-center">
      <CtaButton label="QUERO COMEÇAR MEU PASSO A PASSO HOJE" />
    </div>
  </div>
</section>
