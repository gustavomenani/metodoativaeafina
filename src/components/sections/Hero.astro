---
import { Image } from "astro:assets";
import CtaButton from "../ui/CtaButton.astro";
import heroImage from "../../assets/images/hero/antes-depois.webp";
import { content } from "../../config/site";

const h = content.hero;
---

<section
  class="relative overflow-hidden bg-white"
  aria-labelledby="hero-title"
>
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-olive-soft/60 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-teal-soft/50 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <!-- Layout: título em cima → foto → texto curto → CTA (como página antiga) -->
  <div class="relative mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14 lg:py-16">
    <p
      class="reveal mb-4 text-center text-xs font-semibold uppercase tracking-[0.18em] text-teal"
    >
      {h.eyebrow}
    </p>

    <h1
      id="hero-title"
      class="reveal reveal-delay-1 text-center font-display text-[1.7rem] font-bold leading-[1.18] tracking-tight text-ink sm:text-3xl md:text-4xl"
    >
      {h.title}
    </h1>

    <!-- Foto de impacto (LCP) — sem legenda repetida (texto já está na imagem) -->
    <figure class="reveal reveal-delay-2 mx-auto mt-7 max-w-md sm:mt-9 sm:max-w-lg">
      <div
        class="overflow-hidden rounded-2xl bg-slate-50 shadow-lg shadow-ink/10 ring-1 ring-slate-100"
      >
        <Image
          src={heroImage}
          alt={h.imageAlt}
          widths={[360, 480, 640, 800, 1000]}
          sizes="(max-width: 640px) 90vw, 512px"
          formats={["avif", "webp"]}
          quality={85}
          loading="eager"
          decoding="sync"
          fetchpriority="high"
          class="h-auto w-full"
        />
      </div>
    </figure>

    <p
      class="reveal reveal-delay-3 mx-auto mt-7 max-w-xl text-center text-base leading-relaxed text-ink-muted sm:mt-8 sm:text-lg"
    >
      {h.p1}
    </p>

    <p
      class="reveal reveal-delay-3 mx-auto mt-4 max-w-xl text-center text-base leading-relaxed text-ink sm:text-lg"
    >
      {h.p2}
    </p>

    <p
      class="reveal reveal-delay-3 mx-auto mt-4 max-w-xl text-center text-base leading-relaxed text-ink-muted sm:text-lg"
    >
      {h.p3Before}
      <strong class="font-semibold text-ink">{h.p3Highlight}</strong>{h.p3After}
    </p>

    <p
      class="reveal reveal-delay-3 mx-auto mt-4 max-w-xl text-center text-base font-medium leading-relaxed text-ink sm:text-lg"
    >
      {h.p4}
    </p>

    <div class="reveal reveal-delay-4 mt-8 flex justify-center sm:mt-10">
      <CtaButton label={h.cta} />
    </div>
  </div>
</section>
