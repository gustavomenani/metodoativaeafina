---
import SectionTitle from "../ui/SectionTitle.astro";
import { content } from "../../config/site";

const faqSection = content.faq;
const faqs = faqSection.items;
---

<section
  class="bg-white py-14 sm:py-20"
  aria-labelledby="faq-title"
  id="faq"
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6">
    <SectionTitle
      id="faq-title"
      eyebrow={faqSection.eyebrow}
      title={faqSection.title}
      class="mb-8 sm:mb-10"
    />

    <div class="space-y-3">
      {
        faqs.map((faq, i) => (
          <details
            class:list={[
              "reveal group rounded-2xl border border-slate-100 bg-surface open:bg-olive-soft/30 open:ring-1 open:ring-olive-light/50",
              i % 2 === 1 && "reveal-delay-1",
            ]}
          >
            <summary class="flex items-center justify-between gap-3 px-4 py-4 sm:px-5 sm:py-5">
              <span class="text-left text-sm font-semibold text-ink sm:text-base">
                {faq.q}
              </span>
              <span
                class="faq-chevron flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal/10 text-teal transition-transform duration-200"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </span>
            </summary>
            <div class="border-t border-slate-100/80 px-4 pb-4 pt-1 sm:px-5 sm:pb-5">
              <p class="text-sm leading-relaxed text-ink-muted sm:text-base">
                {faq.a}
              </p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
