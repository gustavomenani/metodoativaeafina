---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Método Ativa & Afina — Afine sua cintura em 8 semanas",
  description = "Ative o transverso do abdômen e conquiste uma barriga mais reta em apenas 8 semanas, sem dietas restritivas e sem centenas de abdominais. Método criado por Lilian Ferancini e Emanuela (Manu).",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5c400" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pt_BR" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.site?.href ?? "/"} />

    <!-- Fonts: preconnect + display=swap (performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-surface text-ink antialiased">
    <a
      href="#conteudo"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-sun focus:px-4 focus:py-2 focus:font-semibold focus:text-ink"
    >
      Ir para o conteúdo
    </a>

    <main id="conteudo">
      <slot />
    </main>

    <!-- Scroll reveal: único JS da página (vanilla) -->
    <script>
      import "../scripts/scroll-reveal.ts";
    </script>
  </body>
</html>
